/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Force revalidation of the HTML shell on every navigation.
# Without this, Cloudflare caches index.html and users get a stale shell
# pointing at old JS chunk hashes after each deploy.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Vite content-hashes all asset filenames, so they are safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
